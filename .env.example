# Copy this file to .env and fill in real values before running off-platform.
# On Replit these are provided automatically; you only set them yourself elsewhere.

# --- Shared ---

# PostgreSQL connection string used by the API server and DB tooling.
DATABASE_URL=postgres://user:password@localhost:5432/ags

# Node environment: "development" or "production".
NODE_ENV=development

# Optional log verbosity for the API server: trace|debug|info|warn|error|fatal.
# Defaults to info if unset.
LOG_LEVEL=info

# --- Per-service (PORT and BASE_PATH) ---
# Each app reads PORT (and the web apps also read BASE_PATH) and will refuse to
# start if they are missing. On Replit the workflows inject these per service.
# Off-platform, set them inline when starting each app, e.g.:
#
#   API server (no BASE_PATH needed):
#     PORT=5000 pnpm --filter @workspace/api-server run dev
#
#   AGS Fretboard web app:
#     PORT=5173 BASE_PATH=/ pnpm --filter @workspace/ags-fretboard run dev
#
#   Guitar Practice web app:
#     PORT=5174 BASE_PATH=/ pnpm --filter @workspace/guitar-practice run dev
#
# BASE_PATH is the URL prefix the web app is served under. Use "/" when running
# a single app at the domain root, or "/ags/" to mirror the Replit routing.

# --- Authentication (Clerk) ---
# On Replit these come from the managed Clerk tenant automatically. Off-platform,
# create your own Clerk application (clerk.com) and paste its keys here.
#
# Frontend (Vite, must be prefixed VITE_). The web app's publishable key.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
# Optional: only set if you front Clerk with a proxy. Leave unset otherwise.
# VITE_CLERK_PROXY_URL=
#
# API server (Clerk session verification / proxy).
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
#
# Optional: comma-separated Clerk user IDs that are always treated as premium
# (useful for the owner account during testing). Leave unset for none.
# PREMIUM_OWNER_CLERK_IDS=user_xxx,user_yyy

# --- Payments (Stripe) ---
# On Replit, Stripe credentials come from the connected Stripe integration and
# you do NOT set these. Off-platform, set your own Stripe keys here and the API
# server will use them automatically.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Optional but recommended for verifying Stripe webhooks.
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
